# ================================
# AnchorScaffold Configuration
# ================================

# OpenAI API Key (optional — required for AI-powered generation mode)
# Without this, AnchorScaffold uses template-only mode.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model to use for code generation
OPENAI_MODEL=gpt-4o

# ================================
# Scaffold Settings
# ================================

# Default output directory for generated projects
OUTPUT_DIR=./output

# Default Anchor version to target
ANCHOR_VERSION=0.30.0

# Default Solana cluster for Anchor.toml
SOLANA_CLUSTER=localnet

# Include TypeScript client SDK stub
GENERATE_CLIENT=true

# ================================
# Logging
# ================================
LOG_LEVEL=INFO
